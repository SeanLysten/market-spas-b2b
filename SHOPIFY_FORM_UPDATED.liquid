{% comment %} Ne pas modifier en dessous de cette ligne {% endcomment %}
<div class="devis-form-wrapper" style="background-color: {{ couleur_fond }};">
  <div class="devis-form-container">
    <h2 class="devis-form-title">{{ titre_formulaire }}</h2>
    <p class="devis-form-subtitle">{{ sous_titre }}</p>

    {% form 'contact' %}
      <input type="hidden" name="contact[to]" id="email_destination" value="france@marketspas.com">
      
      {% if form.posted_successfully? %}
        <div class="form-success">
          <p>{{ msg_succes }}</p>
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="form-error">
          <p>{{ msg_erreur }}</p>
        </div>
      {% endif %}

      {% comment %} Pays {% endcomment %}
      <div class="form-group">
        <label for="pays" class="form-label required">{{ label_pays }}</label>
        <select id="pays" name="contact[pays]" required class="form-input">
          <option value="">{{ select_pays }}</option>
          <option value="France">France</option>
          <option value="Belgique">Belgique / België</option>
          <option value="Luxembourg">Luxembourg</option>
          <option value="Espagne">Espagne / España</option>
        </select>
      </div>

      {% comment %} Type de projet {% endcomment %}
      <div class="form-section">
        <label class="form-label required">{{ label_projet }}</label>
        <div class="projet-options">
          <div class="projet-option">
            <input type="radio" id="spa_standard" name="contact[type_projet]" value="{{ option_spa_standard }}" required>
            <label for="spa_standard">{{ option_spa_standard }}</label>
          </div>
          <div class="projet-option">
            <input type="radio" id="spa_nage" name="contact[type_projet]" value="{{ option_spa_nage }}">
            <label for="spa_nage">{{ option_spa_nage }}</label>
          </div>
          <div class="projet-option">
            <input type="radio" id="produits" name="contact[type_projet]" value="{{ option_produits }}">
            <label for="produits">{{ option_produits }}</label>
          </div>
        </div>
      </div>

      {% comment %} Coordonnees {% endcomment %}
      <div class="form-row">
        <div class="form-group">
          <label for="prenom" class="form-label required">{{ label_prenom }}</label>
          <input type="text" id="prenom" name="contact[prenom]" required class="form-input">
        </div>
        <div class="form-group">
          <label for="nom" class="form-label required">{{ label_nom }}</label>
          <input type="text" id="nom" name="contact[nom]" required class="form-input">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="email" class="form-label required">{{ label_email }}</label>
          <input type="email" id="email" name="contact[email]" required class="form-input">
        </div>
        <div class="form-group">
          <label for="telephone" class="form-label required">{{ label_telephone }}</label>
          <input type="tel" id="telephone" name="contact[telephone]" required class="form-input" placeholder="ex: 06 12 34 56 78">
        </div>
      </div>

      {% comment %} Localisation {% endcomment %}
      <div class="form-row">
        <div class="form-group">
          <label for="code_postal" class="form-label required">{{ label_code_postal }}</label>
          <input type="text" id="code_postal" name="contact[code_postal]" required class="form-input" placeholder="Code postal">
        </div>
        <div class="form-group">
          <label for="ville" class="form-label required">{{ label_ville }}</label>
          <input type="text" id="ville" name="contact[ville]" required class="form-input">
        </div>
      </div>

      {% comment %} Budget {% endcomment %}
      <div class="form-group">
        <label for="budget" class="form-label">{{ label_budget }}</label>
        <select id="budget" name="contact[budget]" class="form-input">
          <option value="">{{ select_budget }}</option>
          <option value="Moins de 5000€">{{ budget_1 }}</option>
          <option value="5000€ - 10000€">{{ budget_2 }}</option>
          <option value="10000€ - 15000€">{{ budget_3 }}</option>
          <option value="15000€ - 20000€">{{ budget_4 }}</option>
          <option value="Plus de 20000€">{{ budget_5 }}</option>
        </select>
      </div>

      {% comment %} Message {% endcomment %}
      <div class="form-group">
        <label for="message" class="form-label">{{ label_message }}</label>
        <textarea id="message" name="contact[message]" class="form-textarea" rows="3" placeholder="{{ placeholder_message }}"></textarea>
      </div>

      <button type="submit" class="form-submit" style="background-color: {{ couleur_principale }};">
        {{ bouton_submit }}
      </button>

      <p class="form-note">{{ note_formulaire }}</p>
    {% endform %}
  </div>
</div>

<style>
  .devis-form-wrapper {
    padding: 60px 20px;
    width: 100%;
  }

  .devis-form-container {
    max-width: 600px;
    margin: 0 auto;
    background: white;
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .devis-form-title {
    font-size: 36px;
    font-weight: 700;
    text-align: center;
    margin: 0 0 10px;
    font-family: var(--font-heading-family);
  }

  .devis-form-subtitle {
    font-size: 18px;
    text-align: center;
    color: #666;
    margin: 0 0 40px;
    font-family: var(--font-body-family);
  }

  .form-success, .form-error {
    padding: 15px 20px;
    border-radius: 10px;
    margin-bottom: 25px;
    text-align: center;
    font-weight: 500;
  }

  .form-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
  .form-success p, .form-error p { margin: 0; font-size: 16px; }
  .form-error { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }

  .form-section { margin-bottom: 25px; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .form-group { margin-bottom: 20px; }
  .form-row .form-group { margin-bottom: 0; }

  .form-label {
    display: block;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
    color: #333;
  }

  .form-label.required::after {
    content: " *";
    color: #e53e3e;
  }

  .form-input, .form-textarea {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid #e0e0e0;
    border-radius: 10px;
    font-size: 16px;
    transition: border-color 0.2s;
    box-sizing: border-box;
    background: white;
    color: #333;
  }

  .form-input:focus, .form-textarea:focus {
    outline: none;
    border-color: #1e3a8a;
  }

  .form-textarea { resize: vertical; min-height: 100px; }

  .projet-options {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }

  .projet-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    flex: 1;
    min-width: 140px;
  }

  .projet-option:has(input:checked) {
    border-color: #1e3a8a;
    background: #eff6ff;
  }

  .projet-option input[type="radio"] { accent-color: #1e3a8a; }

  .form-submit {
    width: 100%;
    padding: 16px;
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    position: relative;
    margin-top: 10px;
  }

  .form-submit:hover { opacity: 0.9; transform: translateY(-1px); }
  .form-submit:active { transform: translateY(0); }

  .form-submit.loading { opacity: 0.7; cursor: not-allowed; }
  .form-submit.loading::after {
    content: '';
    position: absolute;
    width: 20px; height: 20px;
    top: 50%; left: 50%;
    margin-left: -10px; margin-top: -10px;
    border: 2px solid white;
    border-radius: 50%;
    border-top-color: transparent;
    animation: spinner 0.8s linear infinite;
  }

  @keyframes spinner { to { transform: rotate(360deg); } }

  .form-note { text-align: center; font-size: 14px; color: #666; margin-top: 20px; margin-bottom: 0; }

  @media screen and (max-width: 749px) {
    .devis-form-container { padding: 30px 20px; }
    .devis-form-title { font-size: 28px; }
    .devis-form-subtitle { font-size: 16px; }
    .form-row { grid-template-columns: 1fr; gap: 15px; }
    .form-row .form-group { margin-bottom: 15px; }
  }

  @media screen and (max-width: 480px) {
    .devis-form-container { padding: 25px 15px; }
    .devis-form-title { font-size: 24px; }
    .form-submit { font-size: 16px; padding: 14px; }
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  var form = document.querySelector('form[action*="contact"]');
  if (!form) return;

  // ── URL de l'API Market Spas (à mettre à jour avec votre domaine) ──
  var MARKET_SPAS_API = "https://marketspas.pro/api/leads/inbound";

  var paysSelect = document.getElementById("pays");
  var emailDest = document.getElementById("email_destination");
  var cpInput = document.getElementById("code_postal");
  var telInput = document.getElementById("telephone");

  var paysConfig = {
    "France": {
      email: "france@marketspas.com",
      cpLength: 5,
      cpPattern: "[0-9]{5}",
      cpPlaceholder: "75001",
      telPlaceholder: "06 12 34 56 78"
    },
    "Belgique": {
      email: "info@marketspas.com",
      cpLength: 4,
      cpPattern: "[0-9]{4}",
      cpPlaceholder: "1000",
      telPlaceholder: "0470 12 34 56"
    },
    "Luxembourg": {
      email: "info@marketspas.com",
      cpLength: 4,
      cpPattern: "[0-9]{4}",
      cpPlaceholder: "1234",
      telPlaceholder: "621 123 456"
    },
    "Espagne": {
      email: "es@spas-wellis.com",
      cpLength: 5,
      cpPattern: "[0-9]{5}",
      cpPlaceholder: "28001",
      telPlaceholder: "612 345 678"
    }
  };

  paysSelect.addEventListener("change", function() {
    var pays = this.value;
    if (pays && paysConfig[pays]) {
      var config = paysConfig[pays];
      emailDest.value = config.email;
      cpInput.setAttribute("maxlength", config.cpLength);
      cpInput.setAttribute("pattern", config.cpPattern);
      cpInput.setAttribute("placeholder", config.cpPlaceholder);
      cpInput.value = "";
      telInput.setAttribute("placeholder", config.telPlaceholder);
      telInput.value = "";
    }
  });

  var options = document.querySelectorAll('.projet-option');
  options.forEach(function(option) {
    option.addEventListener('click', function() {
      var radio = this.querySelector('input[type="radio"]');
      if (radio) radio.checked = true;
    });
  });

  cpInput.addEventListener("input", function() {
    var pays = paysSelect.value;
    var maxLength = paysConfig[pays] ? paysConfig[pays].cpLength : 5;
    this.value = this.value.replace(/\D/g, "").slice(0, maxLength);
  });

  telInput.addEventListener("input", function() {
    var val = this.value.replace(/\D/g, "");
    var pays = paysSelect.value;
    if (val.length > 0) {
      if (pays === "France") {
        var parts = val.match(/.{1,2}/g);
        if (parts) this.value = parts.join(" ").slice(0, 14);
      } else if (pays === "Belgique") {
        if (val.length <= 4) this.value = val;
        else this.value = val.slice(0, 4) + " " + val.slice(4).match(/.{1,2}/g).join(" ").slice(0, 11);
      } else if (pays === "Luxembourg") {
        if (val.length <= 3) this.value = val;
        else this.value = val.slice(0, 3) + " " + val.slice(3).match(/.{1,3}/g).join(" ").slice(0, 11);
      } else {
        this.value = val.slice(0, 15);
      }
    }
  });

  // ── Intercepter la soumission pour envoyer à l'API Market Spas ──────────
  form.addEventListener("submit", function(e) {
    var btn = form.querySelector(".form-submit");
    if (btn) {
      btn.classList.add("loading");
      btn.textContent = "...";
    }

    // Collecter les données du formulaire
    var formData = {
      firstName: document.getElementById("prenom") ? document.getElementById("prenom").value : "",
      lastName: document.getElementById("nom") ? document.getElementById("nom").value : "",
      email: document.getElementById("email") ? document.getElementById("email").value : "",
      phone: document.getElementById("telephone") ? document.getElementById("telephone").value : "",
      postalCode: document.getElementById("code_postal") ? document.getElementById("code_postal").value : "",
      city: document.getElementById("ville") ? document.getElementById("ville").value : "",
      country: paysSelect ? paysSelect.value : "",
      productInterest: (function() {
        var checked = form.querySelector('input[name="contact[type_projet]"]:checked');
        return checked ? checked.value : "";
      })(),
      budget: document.getElementById("budget") ? document.getElementById("budget").value : "",
      message: document.getElementById("message") ? document.getElementById("message").value : "",
      source: "WEBSITE"
    };

    // Envoyer à l'API Market Spas en arrière-plan (sans bloquer Shopify)
    fetch(MARKET_SPAS_API, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(formData)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      console.log("[MarketSpas] Lead enregistré:", data);
    })
    .catch(function(err) {
      // Silencieux — ne pas bloquer la soumission Shopify
      console.warn("[MarketSpas] Erreur envoi lead:", err);
    });

    // Meta Pixel - Tracking Lead
    if (typeof fbq === 'function') {
      fbq('track', 'Lead', {
        content_name: 'devis_spa',
        content_category: 'formulaire_devis',
        value: 0,
        currency: 'EUR'
      });
    }

    // Laisser Shopify gérer la soumission normalement
  });
});
