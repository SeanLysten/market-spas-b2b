  "query": "\n-- Trouver les territoires orphelins (partnerId qui n'existe plus dans partners)\nSELECT pt.id, pt.partnerId, pt.regionId, r.code, r.name\nFROM partner_territories pt\nJOIN regions r ON r.id = pt.regionId\nLEFT JOIN partners p ON p.id = pt.partnerId\nWHERE p.id IS NULL;\n",
